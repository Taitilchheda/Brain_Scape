# Brain_Scape — Environment Variables
# Copy to .env and fill in values

# ── Database ──
DATABASE_URL=postgresql://brainscape:brainscape@localhost:5432/brainscape
REDIS_URL=redis://localhost:6379/0

# ── Object Storage ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=brainscape-scans

# ── LLM ──
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ── RAG / Vector Store ──
VECTOR_STORE=weaviate
WEAVIATE_URL=http://localhost:8080
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ── Embedding ──
EMBEDDING_MODEL=pubmedbert
EMBEDDING_DIMENSION=768

# ── Authentication ──
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption ──
ENCRYPTION_KEY=change-this-to-a-32-byte-key

# ── Compliance ──
DATA_RESIDENCY_REGION=US
PHI_SCRUBBING_ENABLED=true

# ── MLflow ──
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=brainscape

# ── Worker ──
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── GPU ──
CUDA_VISIBLE_DEVICES=0
GPU_WORKER_COUNT=2
CPU_WORKER_COUNT=4

# ── Monitoring ──
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000